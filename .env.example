# Copy this file to `.env` in the repo root and fill in real values. NEVER commit `.env`.
# `docker compose up` reads this one file for both the backend and frontend services.

# ---- Database (remote Supabase — no local Postgres container in this stack) ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-key

# ---- LLM gateway (OpenAI-compatible — OpenAI itself, or a LiteLLM proxy, etc.) ----
LLM_BASE_URL=https://your-llm-proxy/v1
LLM_API_KEY=sk-your-llm-key
LLM_MODEL=gpt-4o-mini

# ---- Email (Resend) ----
RESEND_API_KEY=re_your-resend-key
REPORT_FROM_EMAIL=assessments@yourdomain.com

# ---- Frontend ----
# The URL the candidate's BROWSER uses to reach the backend. Baked into the frontend's build at
# `docker compose build` time — changing this after a build requires rebuilding the frontend
# image, not just restarting the container. Default is correct for running everything locally.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000