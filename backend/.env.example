# Copy to .env and fill in. NEVER commit .env.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-service-role-or-anon-key

# OpenAI-compatible LLM endpoint (OpenAI, or a LiteLLM proxy, etc.)
LLM_BASE_URL=https://your-llm-proxy/v1
LLM_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini

# Email (Resend). The loop runs without it, but real send + a persisted email_logs row per delivery
# is an in-scope v1 deliverable — fill this in before the assessment is "done".
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=assessments@yourdomain.com